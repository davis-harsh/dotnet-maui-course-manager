<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:Milestone"
             x:Class="Milestone.NotificationsPage"
             Title="NotificationsPage">
    
    <ScrollView>
        <VerticalStackLayout Margin="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <ImageButton Source="wgulogo.png" MaximumHeightRequest="25" Grid.Column="0" Grid.Row="0" HorizontalOptions="Start" Clicked="wgulogo_Clicked"/>
                <ImageButton Source="homeicon.png" MaximumHeightRequest="25" Grid.Column="3" Grid.Row="0" Clicked="wgulogo_Clicked"/>
                <ImageButton Source="termicon.png" MaximumHeightRequest="25" Grid.Column="4" Grid.Row="0" Clicked="termListPageButton_Clicked"/>
                <ImageButton Source="coursesicon.png" MaximumHeightRequest="25" Grid.Column="5" Grid.Row="0" Clicked="courseListPageButton_Clicked"/>
                <ImageButton Source="notificationsicon.png" MaximumHeightRequest="25" Grid.Column="6" Grid.Row="0" Clicked="notificationsSettingsButton_Clicked"/>
            </Grid>

            <Label Text="Notifications:" Margin="0,25,0,0" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center"/>

            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Label Text="Course Notifications" FontSize="16" VerticalOptions="Center" Grid.Column="1" Grid.Row="0"/>
                <Switch x:Name="courseNotificationSwitch" ThumbColor="Navy" OnColor="LightGray" Toggled="OnCourseToggled" Grid.Column="2" Grid.Row="0"/>
                <Label Text="Assessment Notifications" FontSize="16" VerticalOptions="Center" Grid.Column="1" Grid.Row="1"/>
                <Switch x:Name="assessmentNotificationSwitch" ThumbColor="Navy" OnColor="LightGray" Toggled="OnAssessmentToggled" Grid.Column="2" Grid.Row="1"/>
            </Grid>

            <Label Text="Recent Notifications:" Margin="5,10,5,0" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Start"/>
            
            <ListView x:Name="deliveredListView" HasUnevenRows="True" Margin="10,0,10,0">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <StackLayout Padding="10">
                                <Label Text="{Binding Title}" FontAttributes="Bold" FontSize="16" />
                                <Label Text="{Binding Description}" MaxLines="3" FontSize="14" />
                                <Label Text="{Binding Schedule.NotifyTime, StringFormat='Delivered at: {0:g}'}"
                           FontSize="12"
                           TextColor="Gray" />
                            </StackLayout>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>