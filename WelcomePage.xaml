<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:local="clr-namespace:Milestone"
             x:Class="Milestone.WelcomePage"
             Title="WelcomePage">

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0">
            <VerticalStackLayout Margin="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ImageButton Source="wgulogo.png" MaximumHeightRequest="25" Grid.Column="0" Grid.Row="0" HorizontalOptions="Start" Clicked="wgulogo_Clicked"/>
                    <ImageButton Source="homeicon.png" MaximumHeightRequest="25" Grid.Column="3" Grid.Row="0"/>
                    <ImageButton Source="termicon.png" MaximumHeightRequest="25" Grid.Column="4" Grid.Row="0" Clicked="termListPageButton_Clicked"/>
                    <ImageButton Source="coursesicon.png" MaximumHeightRequest="25" Grid.Column="5" Grid.Row="0" Clicked="courseListPageButton_Clicked"/>
                    <ImageButton Source="notificationsicon.png" MaximumHeightRequest="25" Grid.Column="6" Grid.Row="0" Clicked="notificationsSettingsButton_Clicked"/>
                </Grid>

                <Label x:Name="greetingLabel" FontSize="24" FontAttributes="Bold" HorizontalTextAlignment="Center" Margin="0,25,0,0"/>

                <Label Text="Active Courses:" FontSize="20" FontAttributes="Bold" Margin="0,25,0,0" HorizontalTextAlignment="Center"/>
                <CollectionView x:Name="activeCoursesView"
                ItemsLayout="VerticalList"
                ItemsSource="{Binding ActiveCourses}"
                IsVisible="{Binding HasActiveCourses}"
                Margin="0,5,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10" Margin="5" HasShadow="True" BorderColor="LightGray">
                                <Grid Padding="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Label Text="{Binding Name}"
                           FontAttributes="Bold"
                           FontSize="20"
                           Grid.Column="0" Grid.Row="0" />

                                    <Label Text="{Binding CUs}"
                           FontSize="16"
                           FontAttributes="Bold"
                           Grid.Column="2" Grid.Row="0" />

                                    <Label Text="{Binding Summary}"
                           LineBreakMode="WordWrap"
                           MaxLines="3"
                           FontSize="14"
                           Grid.Column="0"
                           Grid.Row="1"
                           Grid.ColumnSpan="3" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Label Text="Completed Courses:" FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center" Margin="0,10,0,0"/>
                <CollectionView x:Name="completedCoursesView"
                            ItemsSource="{Binding CompletedCourses}"
                            IsVisible="{Binding HasCompletedCourses}"
                            Margin="0,5,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame Padding="10" Margin="5" HasShadow="True" BorderColor="LightGray">
                                <Grid Padding="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>

                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Label Text="{Binding Name}"
                                       FontSize="20"
                                       FontAttributes="Bold"
                                       Grid.Column="0"
                                       Grid.Row="0" />
                                    <Label Text="{Binding CUs}"
                                       FontSize="16"
                                       FontAttributes="None"
                                       Grid.Column="2"
                                       Grid.Row="0"/>
                                    <Label Text="{Binding CompletedOn, StringFormat='Completed on: {0:MMMM dd, yyyy}'}"
                                       FontSize="14"
                                       TextColor="DarkGreen"
                                       Grid.Column="0"
                                       Grid.Row="1" />
                                </Grid>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <VerticalStackLayout Grid.Row="1" Padding="10">
            <Label Text="Software Engineering Capstone — D424" HorizontalTextAlignment="Center" Margin="0,10,0,0" FontSize="12"/>
            <Label Text="Developed by Davis Harsh, Student ID: 000693623" HorizontalTextAlignment="Center" Margin="0,10,0,0" FontSize="12"/>
        </VerticalStackLayout>
    </Grid>
</ContentPage>